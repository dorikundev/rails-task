<div class="container py-5">
  <h2 class="fs-4 fw-bold">
    <i class="bi bi-calendar"></i>
    スケジュール登録
  </h2>

  <!-- 登録エラーメッセージ -->
  <%= render 'shared/error', obj: @post %>

  <!-- 入力フォーム -->
  <div class="card mt-4">
    <div class="card-body p-4">
      <%= form_with model: @post, class: "needs-validation" do |f| %>
        
        <div class="mb-3 fw-bold">
          <%= f.label :title, "タイトル", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", placeholder: "タイトルを20文字以内で入力" %>
        </div>

        <div class="mb-3 fw-bold">
          <div class="row g-4">
            <div class="col-md-6">
              <%= f.label :title, "開始日", class: "form-label" %>
              <%= f.date_field :start_date, class: "form-control" %>
            </div>
            <div class="col-md-6">
              <%= f.label :title, "終了日", class: "form-label" %>
              <%= f.date_field :end_date, class: "form-control" %>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <div class="form-check">
            <%= f.check_box :all_day, class: "form-check-input" %>
            <%= f.label :all_day, "終日の場合はチェックをつけてください", class: "form-check-label" %>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :memo, "スケジュールメモ", class: "form-label" %>
          <%= f.text_area :memo, class: "form-control", rows: 3 , placeholder: "メモを500文字以内で入力"%>
        </div>

        <div class="d-flex gap-3 justify-content-end">
          <%= link_to "キャンセル", :posts, class: "btn btn-outline-secondary px-4 py-2" %>
          <%= f.submit "登録する", class: "btn btn-primary px-4 py-2" %>
        </div>

      <% end %>
    </div>
  </div>
</div>